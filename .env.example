# Local dev runs with NERF_BACKEND=local and zero extra config.
# For the real GPU path, copy to .env and fill these in:

# NERF_BACKEND=runpod

# RunPod Serverless endpoint that runs worker/ (see worker/README.md)
# RUNPOD_API_KEY=...
# RUNPOD_ENDPOINT_ID=...

# S3-compatible bucket for moving frames + results (Cloudflare R2 shown)
# S3_BUCKET=nerf-assets
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=auto

# LOCAL_DELAY_SECONDS=3   # make local jobs visibly poll
