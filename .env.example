# Local dev runs with zero extra config (CPU stand-in pipeline).
# APP_MODULE=solution_app   # which file Render serves: solution_app (reference) or app (yours)
# NERF_BACKEND=local        # only "local" is implemented in app.py; "runpod" is phase 2
# CORS_ALLOW_ORIGINS=*
# LOCAL_DELAY_SECONDS=3     # make local jobs take longer so the client visibly polls

# --- Phase 2 (real GPU on RunPod, exchanging files via S3/R2) lives in worker/.
# The API-side RunPod wiring is not in app.py yet; see worker/README.md.
