# Local dev runs with zero extra config (CPU pipeline).
# APP_MODULE=solution_app   # which file Render serves: solution_app (reference) or app (yours)
# NERF_BACKEND=local        # "local" = in-process CPU pipeline; "runpod" = remote GPU (below)
# CORS_ALLOW_ORIGINS=*
# LOCAL_DELAY_SECONDS=3      # make local jobs take longer so the client visibly polls

# --- RunPod GPU backend (set NERF_BACKEND=runpod) ----------------------------
# The API uploads frames to S3/R2, submits a job to a RunPod Serverless endpoint
# (running worker/), polls it, and redirects /result to the finished .ply.
# RUNPOD_API_KEY=...                  # RunPod account API key
# RUNPOD_ENDPOINT_ID=...              # the Serverless endpoint id
#
# S3-compatible storage for file exchange (Cloudflare R2 shown; AWS S3 also works):
# S3_BUCKET=nerf-service
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com   # omit for real AWS S3
# S3_REGION=auto                      # "auto" for R2; a real region for AWS
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# PRESIGN_EXPIRY_SECONDS=3600         # how long presigned urls stay valid
